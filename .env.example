# -----------------------------------------------
# Viewcake — Environment Variables
# Copy to .env and fill in real values.
# Never commit .env to Git.
# -----------------------------------------------

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://viewcake_user:change-this-password@localhost:5432/viewcake"

# Auth.js secret — used to sign JWT session tokens
# Generate: openssl rand -base64 32
AUTH_SECRET="replace-with-a-real-secret"

# Canonical public URL of this app — used by Auth.js for redirect URIs
# Must match the URL users actually reach the app on
AUTH_URL="https://viewcake.brightening.ca"

# General app base URL (same as AUTH_URL in most setups)
APP_URL="https://viewcake.brightening.ca"

# Required when running behind a reverse proxy or Cloudflare tunnel.
# Tells Auth.js to trust the forwarded host header.
AUTH_TRUST_HOST=true
